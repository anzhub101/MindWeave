{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audit_report_schema_v1",
  "type": "object",
  "required": [
    "company_name",
    "fiscal_year",
    "audit_opinion",
    "opinion_basis",
    "overall_materiality",
    "key_metrics",
    "identified_risks",
    "substantive_findings",
    "verification_summary",
    "evidence_sources",
    "trace_references",
    "executive_summary"
  ],
  "properties": {
    "company_name": {
      "type": "string"
    },
    "fiscal_year": {
      "type": "string"
    },
    "audit_opinion": {
      "type": "string",
      "enum": ["Unqualified", "Qualified", "Adverse", "Disclaimer"]
    },
    "opinion_basis": {
      "type": "string"
    },
    "overall_materiality": {
      "type": "number"
    },
    "key_metrics": {
      "type": "object",
      "required": ["revenue", "net_income", "total_assets", "total_liabilities_and_equity"],
      "properties": {
        "revenue": {"type": "number"},
        "net_income": {"type": "number"},
        "total_assets": {"type": "number"},
        "total_liabilities_and_equity": {"type": "number"},
        "gross_margin": {"type": "number"},
        "net_margin": {"type": "number"}
      },
      "additionalProperties": true
    },
    "identified_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "rationale", "evidence_refs"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "severity": {"type": "string", "enum": ["low", "medium", "high"]},
          "rationale": {"type": "string"},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    },
    "substantive_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "amount", "summary", "evidence_refs"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string"},
          "amount": {"type": "number"},
          "summary": {"type": "string"},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    },
    "verification_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "status", "checks"],
        "properties": {
          "node_id": {"type": "string"},
          "status": {"type": "string"},
          "checks": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    },
    "evidence_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_id", "name", "sha256"],
        "properties": {
          "document_id": {"type": "string"},
          "name": {"type": "string"},
          "sha256": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "trace_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "thought_id", "summary"],
        "properties": {
          "node_id": {"type": "string"},
          "thought_id": {"type": "string"},
          "summary": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "executive_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

